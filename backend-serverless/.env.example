# StoryTeller backend environment variables
# Copy to .env and edit before running.

ENVIRONMENT=dev

# Postgres connection (asyncpg driver). For local dev with docker-compose:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/storyteller

# JWT signing secret. MUST be a long, random string in production.
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
# Use true in production if automatic environment detection is not enough.
AUTH_COOKIE_SECURE=false

# Frontend + Google OAuth redirect flow
FRONTEND_BASE_URL=http://localhost:5174
# Production:
# FRONTEND_BASE_URL=https://storyteller.reubinoff.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:7071/api/v1/auth/google/callback

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=4096

# Azure Functions / queue worker. local.settings.json is preferred for func start.
AzureWebJobsStorage=UseDevelopmentStorage=true
EVALUATION_QUEUE_NAME=writing-evaluations
CREATE_EVALUATION_QUEUE_ON_ENQUEUE=true

# Comma-separated list (or JSON list) of allowed frontend origins.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","https://storyteller.reubinoff.com"]

# Run the static catalog seeder on startup (idempotent).
SEED_ON_STARTUP=true
# Auto-create tables on startup (set false in prod; use Alembic instead).
AUTO_CREATE_SCHEMA=false
